#!/usr/bin/env php
<?php

/**
 * Freezed CLI entry point.
 *
 * Works in three layouts:
 *  - Installed as a Composer dependency  (vendor/bin/freezed -> proxy sets $_composer_autoload_path)
 *  - Cloned/standalone package           (bin/freezed with its own vendor/)
 *  - Inside a project skeleton           (the project's vendor/autoload.php)
 */

/* ---------------------------------------------------------------------------
 * 1) Locate and load the Composer autoloader.
 * ------------------------------------------------------------------------- */
$autoloadCandidates = [
    $_composer_autoload_path ?? null,          // set by the Composer bin proxy
    __DIR__ . '/../vendor/autoload.php',       // standalone clone of this package
    __DIR__ . '/../../../autoload.php',         // installed in vendor/neuedaten/freezed/bin
    __DIR__ . '/../../../../vendor/autoload.php',
];

$autoloadFound = false;
foreach ($autoloadCandidates as $candidate) {
    if ($candidate && file_exists($candidate)) {
        require $candidate;
        $autoloadFound = true;
        break;
    }
}

if (!$autoloadFound) {
    fwrite(STDERR, "Freezed: could not locate Composer autoloader. Run 'composer install' first." . PHP_EOL);
    exit(1);
}

use Neuedaten\Freezed\Commands\CompileCommand;
use Neuedaten\Freezed\Commands\InstallCommand;
use Neuedaten\Freezed\Commands\RunCommand;
use Neuedaten\Freezed\Commands\ServeCommand;
use Neuedaten\Freezed\Commands\WatchCommand;
use Neuedaten\Freezed\Services\ConfigService;
use Neuedaten\Freezed\Services\LogService;

/* ---------------------------------------------------------------------------
 * 2) Determine the project root (where the site lives).
 *    Priority: FREEZED_ROOT env > directory containing freezed.config.php
 *    (searched upward from CWD) > current working directory.
 * ------------------------------------------------------------------------- */
$configFileName = 'freezed.config.php';

function freezed_resolve_project_root(string $configFileName): string
{
    // Explicit override wins.
    $envRoot = getenv('FREEZED_ROOT');
    if ($envRoot && is_dir($envRoot)) {
        return realpath($envRoot);
    }

    // Walk up from the current working directory looking for the config file.
    $dir = getcwd() ?: __DIR__;
    $previous = null;
    while ($dir && $dir !== $previous) {
        if (file_exists($dir . DIRECTORY_SEPARATOR . $configFileName)) {
            return $dir;
        }
        $previous = $dir;
        $dir = dirname($dir);
    }

    // No config found yet (e.g. before `install`): use the current directory.
    return getcwd() ?: __DIR__;
}

/**
 * Resolve the path used to re-invoke this CLI from spawned subprocesses
 * (watch/run rebuilds and the dev server).
 *
 * When Freezed runs as a Composer dependency, the real entry point is the
 * generated bin proxy (vendor/bin/freezed), which sets $_composer_autoload_path
 * before including this file. This file itself is reached through a symlink, so
 * realpath(__FILE__) points at the package's own bin — spawning that directly
 * would bypass the proxy and the child process could not locate the autoloader
 * ("could not locate Composer autoloader"). Prefer the proxy when present and
 * fall back to this file for standalone clones.
 */
function freezed_resolve_cli_bin(): string
{
    $composerBinDir = $GLOBALS['_composer_bin_dir'] ?? null;
    if (is_string($composerBinDir) && $composerBinDir !== '') {
        $proxy = $composerBinDir . DIRECTORY_SEPARATOR . 'freezed';
        if (file_exists($proxy)) {
            return $proxy;
        }
    }

    return realpath(__FILE__) ?: __FILE__;
}

/* ---------------------------------------------------------------------------
 * 3) Parse the command.
 * ------------------------------------------------------------------------- */
// Separate options (--key:value) from positional arguments so that the task
// can be combined with build options, e.g. `freezed build --enviroment:development`.
$positionalArgs = [];
$buildConfig = freezed_parse_build_options(array_slice($argv, 1), $positionalArgs);

// Keep the raw option tokens (e.g. --enviroment:development, --log) so commands
// that spawn a fresh build subprocess (watch, run) can forward them verbatim.
$optionArgs = array_values(array_filter(
    array_slice($argv, 1),
    static fn (string $arg): bool => str_starts_with($arg, '--')
));

$task = $positionalArgs[0] ?? 'compile';

if (in_array($task, ['-h', '--help', 'help'], true) || isset($buildConfig['help'])) {
    freezed_print_help();
    exit(0);
}

if (in_array($task, ['-V', '--version', 'version'], true) || isset($buildConfig['version'])) {
    fwrite(STDOUT, 'Freezed ' . freezed_version() . PHP_EOL);
    exit(0);
}

$projectRoot = freezed_resolve_project_root($configFileName);

/* ---------------------------------------------------------------------------
 * 4) Load configuration and run.
 * ------------------------------------------------------------------------- */
$configFile = $projectRoot . DIRECTORY_SEPARATOR . $configFileName;
$config = file_exists($configFile) ? include $configFile : [];

$configService = ConfigService::getInstance();
$configService->setConfig($config);
$configService->setValue('[projectRoot]', $projectRoot);
$configService->setValue('[buildConfig]', $buildConfig);

// CLI context for commands that spawn subprocesses (watch, run) or the server.
$configService->setValue('[cli]', [
    'php' => PHP_BINARY,
    'bin' => freezed_resolve_cli_bin(),
    'optionArgs' => $optionArgs,
]);

// Configure logging (verbosity + optional log file) for every command.
LogService::getInstance()->configureFromBuildConfig($buildConfig, $projectRoot);

$exitCode = 0;

switch ($task) {
    case 'install':
    case 'init':
        $exitCode = (new InstallCommand())->execute();
        break;
    case 'serve':
        freezed_require_config($configFile, $configFileName, $projectRoot);
        $exitCode = (new ServeCommand())->execute();
        break;
    case 'watch':
        freezed_require_config($configFile, $configFileName, $projectRoot);
        $exitCode = (new WatchCommand())->execute();
        break;
    case 'run':
        freezed_require_config($configFile, $configFileName, $projectRoot);
        $exitCode = (new RunCommand())->execute();
        break;
    case 'build':
    case 'compile':
    default:
        freezed_require_config($configFile, $configFileName, $projectRoot);
        $exitCode = (new CompileCommand())->execute();
        break;
}

exit($exitCode);

/* ---------------------------------------------------------------------------
 * Helpers
 * ------------------------------------------------------------------------- */
/**
 * Parse CLI build options of the form `--key:value` (e.g. `--enviroment:development`).
 *
 * Everything that is not an option is collected into $positionalArgs (passed by
 * reference) so the caller can still detect the task. Recognised option forms:
 *  --key:value   ->  ['key' => 'value']
 *  --key=value   ->  ['key' => 'value']
 *  --key         ->  ['key' => true]   (flag)
 *
 * @return array<string, mixed> The parsed build configuration.
 */
function freezed_parse_build_options(array $args, array &$positionalArgs): array
{
    $buildConfig = [];

    foreach ($args as $arg) {
        if (str_starts_with($arg, '--')) {
            $option = substr($arg, 2);

            // Support both `:` and `=` as key/value separators.
            $separatorPos = strcspn($option, ':=');
            if ($separatorPos < strlen($option)) {
                $key = substr($option, 0, $separatorPos);
                $value = substr($option, $separatorPos + 1);
            } else {
                $key = $option;
                $value = true;
            }

            if ($key !== '') {
                $buildConfig[$key] = $value;
            }

            continue;
        }

        $positionalArgs[] = $arg;
    }

    return $buildConfig;
}

/**
 * Ensure a project configuration exists before running a build-dependent
 * command. Exits with code 1 and a hint otherwise.
 */
function freezed_require_config(string $configFile, string $configFileName, string $projectRoot): void
{
    if (!file_exists($configFile)) {
        fwrite(STDERR, "Freezed: no $configFileName found in $projectRoot." . PHP_EOL
            . "Run 'freezed install' first to scaffold a project." . PHP_EOL);
        exit(1);
    }
}

/**
 * Resolve the Freezed version.
 *
 * The published composer.json carries no `version` field (Packagist derives it
 * from git tags), so the version is determined in this order:
 *  1. The exact git tag when running from a checkout (`git describe --tags`).
 *  2. A `version` field in composer.json, if one is present.
 *  3. The newest version heading in CHANGELOG.md (shipped with the package).
 *  4. A hard-coded fallback.
 */
function freezed_version(): string
{
    $packageRoot = dirname(__DIR__);

    $gitVersion = freezed_git_version($packageRoot);
    if ($gitVersion !== null) {
        return $gitVersion;
    }

    $composerJson = $packageRoot . '/composer.json';
    if (file_exists($composerJson)) {
        $data = json_decode((string) file_get_contents($composerJson), true);
        if (!empty($data['version'])) {
            return (string) $data['version'];
        }
    }

    $changelogVersion = freezed_changelog_version($packageRoot . '/CHANGELOG.md');
    if ($changelogVersion !== null) {
        return $changelogVersion;
    }

    return '0.1.0-beta';
}

/**
 * Read the version from the nearest git tag, e.g. "0.1.1-beta". Returns null
 * when there is no git checkout, git is unavailable, or no tag is reachable.
 */
function freezed_git_version(string $dir): ?string
{
    if (!is_dir($dir . '/.git') || !function_exists('exec')) {
        return null;
    }

    $command = 'git -C ' . escapeshellarg($dir) . ' describe --tags --dirty 2>/dev/null';
    $status = 1;
    $output = @exec($command, $lines, $status);

    if ($status !== 0 || !is_string($output) || $output === '') {
        return null;
    }

    return ltrim($output, 'v');
}

/**
 * Extract the most recent released version heading from a Keep-a-Changelog file,
 * e.g. "## [0.1.1-beta] - 2026-06-12" -> "0.1.1-beta".
 */
function freezed_changelog_version(string $path): ?string
{
    if (!is_file($path)) {
        return null;
    }

    $contents = (string) file_get_contents($path);
    if (preg_match('/^##\s*\[(\d+\.\d+\.\d+[^\]]*)\]/m', $contents, $matches)) {
        return $matches[1];
    }

    return null;
}

function freezed_print_help(): void
{
    $version = freezed_version();
    fwrite(STDOUT, <<<TXT
Freezed $version — a static site generator powered by TYPO3 Fluid.

Usage:
  freezed <command> [options]

Commands:
  install, init     Scaffold the project (content/, themes/, static/, public/, freezed.config.php).
  build, compile    Render the site into the public/ directory. (default)
  serve             Serve the public/ directory with PHP's built-in web server.
  watch             Rebuild automatically whenever a source file changes.
  run               Build, serve and watch together (development mode).
  help, --help      Show this help.
  version, --version  Show the version.

Options:
  --<key>:<value>   Pass a build option. Options are exposed in templates via
                    the "build" variable, e.g. --enviroment:development is
                    available as {build.enviroment}. Options work with every
                    command and are forwarded to rebuilds in watch/run.
  --host:<host>     Host for serve/run (default localhost).
  --port:<port>     Port for serve/run (default 8080).
  --verbose         Show detailed (info-level) output on the CLI.
  --quiet           Only show errors on the CLI.
  --log             Write the full log to <projectRoot>/freezed.log.
  --log=<path>      Write the full log to the given file.

Environment:
  FREEZED_ROOT      Override the project root directory.

The project root is auto-detected by searching upward from the current
directory for a freezed.config.php file, falling back to the current directory.

TXT);
}
